import re
import sys
import os
import stat
import shutil
import shlex
import subprocess
import unicodedata

DEFAULT_LIMIT_FALLBACK_COL = 100
DEFAULT_LIMIT_FALLBACK_ROW = 24
DEFAULT_LESS_OPTIONS = 'FRX'

ansi_re = re.compile(r'\x1b\[[0-9;]*m')


def _char_width(ch):
    if unicodedata.east_asian_width(ch) in ('F', 'W', 'A'):
        return 2
    return 1


def _is_pipe_or_tty_stdout():
    if sys.stdout.isatty():
        return True

    try:
        mode = os.fstat(sys.stdout.fileno()).st_mode
    except OSError:
        return False

    return stat.S_ISFIFO(mode)


def _get_terminal_columns_from_stream(stream):
    try:
        columns = os.get_terminal_size(stream.fileno()).columns
    except (AttributeError, OSError):
        return None

    if columns <= 0:
        return None

    return columns


def _get_terminal_columns_from_tty():
    try:
        tty = os.open('/dev/tty', os.O_RDONLY)
    except OSError:
        return None

    try:
        columns = os.get_terminal_size(tty).columns
    except OSError:
        return None
    finally:
        os.close(tty)

    if columns <= 0:
        return None

    return columns


def _get_terminal_columns_from_environment():
    try:
        columns = int(os.environ.get('COLUMNS', ''))
    except ValueError:
        return None

    if columns <= 0:
        return None

    return columns


def _get_default_limit():
    for stream in (sys.stdout, sys.stderr, sys.stdin):
        columns = _get_terminal_columns_from_stream(stream)
        if columns is not None:
            return columns

    columns = _get_terminal_columns_from_tty()
    if columns is not None:
        return columns

    columns = _get_terminal_columns_from_environment()
    if columns is not None:
        return columns

    return DEFAULT_LIMIT_FALLBACK_COL


def _parse_positive_int(value, option_name):
    try:
        number = int(value)
    except ValueError:
        print(f"mycut: invalid value for {option_name}: '{value}'", file=sys.stderr)
        sys.exit(2)

    if number <= 0:
        print(f"mycut: invalid value for {option_name}: '{value}'", file=sys.stderr)
        sys.exit(2)

    return number


def _parse_options(argv):
    color_mode = 'auto'
    limit = _get_default_limit()
    use_pager = True
    i = 0

    while i < len(argv):
        arg = argv[i]

        if arg.startswith('--color='):
            value = arg.split('=', 1)[1]
            if value not in ('auto', 'never', 'always'):
                print(f"mycut: invalid argument for --color: '{value}'", file=sys.stderr)
                sys.exit(2)
            color_mode = value
        elif arg == '-n' or arg == '--no-pager':
            use_pager = False
        elif arg == '-c' or arg == '--characters':
            i += 1
            if i >= len(argv):
                print(f"mycut: option requires an argument -- '{arg}'", file=sys.stderr)
                sys.exit(2)
            limit = _parse_positive_int(argv[i], arg)
        elif arg.startswith('--characters='):
            value = arg.split('=', 1)[1]
            limit = _parse_positive_int(value, '--characters')
        else:
            print('usage: mycut [--color=auto|never|always] [-n|--no-pager] [-c N|--characters N|--characters=N]', file=sys.stderr)
            sys.exit(2)

        i += 1

    return color_mode, limit, use_pager


color_mode, limit, use_pager = _parse_options(sys.argv[1:])

if color_mode == 'always':
    keep_color = True
elif color_mode == 'never':
    keep_color = False
else:
    keep_color = _is_pipe_or_tty_stdout()


def _get_terminal_rows_from_stream(stream):
    try:
        rows = os.get_terminal_size(stream.fileno()).lines
    except (AttributeError, OSError):
        return None

    if rows <= 0:
        return None

    return rows


def _get_terminal_rows_from_tty():
    try:
        tty = os.open('/dev/tty', os.O_RDONLY)
    except OSError:
        return None

    try:
        rows = os.get_terminal_size(tty).lines
    except OSError:
        return None
    finally:
        os.close(tty)

    if rows <= 0:
        return None

    return rows


def _get_terminal_rows_from_environment():
    try:
        rows = int(os.environ.get('LINES', ''))
    except ValueError:
        return None

    if rows <= 0:
        return None

    return rows


def _get_terminal_rows():
    for stream in (sys.stdout, sys.stderr, sys.stdin):
        rows = _get_terminal_rows_from_stream(stream)
        if rows is not None:
            return rows

    rows = _get_terminal_rows_from_tty()
    if rows is not None:
        return rows

    rows = _get_terminal_rows_from_environment()
    if rows is not None:
        return rows

    return DEFAULT_LIMIT_FALLBACK_ROW


def _count_screen_rows(text):
    if text == '':
        return 0

    rows = text.count('\n')
    if not text.endswith('\n'):
        rows += 1

    return rows


def _get_pager_command():
    pager = os.environ.get('PAGER')
    if pager:
        try:
            return shlex.split(pager)
        except ValueError:
            return None

    if shutil.which('less') is not None:
        return ['less']

    if shutil.which('more') is not None:
        return ['more']

    return None


def _is_less_command(pager_command):
    if not pager_command:
        return False

    return os.path.basename(pager_command[0]) == 'less'


def _get_pager_environment(pager_command):
    env = os.environ.copy()

    if _is_less_command(pager_command):
        less_options = env.get('LESS', DEFAULT_LESS_OPTIONS)
        if 'R' not in less_options:
            less_options += 'R'
        env['LESS'] = less_options

    return env


def _start_pager(pager_command):
    try:
        return subprocess.Popen(
            pager_command,
            stdin=subprocess.PIPE,
            text=True,
            env=_get_pager_environment(pager_command),
        )
    except OSError:
        return None


def _write_to_pager(pager_process, text):
    try:
        pager_process.stdin.write(text)
    except (BrokenPipeError, OSError):
        return False

    return True


def _finish_pager(pager_process):
    try:
        pager_process.stdin.close()
    except (BrokenPipeError, OSError):
        pass

    pager_process.wait()


def _process_line(line):
    had_newline = line.endswith('\n')
    content = line[:-1] if had_newline else line

    pos = 0
    visible = 0
    out = ""

    while pos < len(content) and visible < limit:
        m = ansi_re.match(content, pos)

        if m:
            if keep_color:
                out += m.group(0)
            pos = m.end()
        else:
            ch = content[pos]
            width = _char_width(ch)
            if visible + width > limit:
                break
            out += ch
            pos += 1
            visible += width

    if keep_color:
        out += "\x1b[0m"

    if had_newline:
        out += '\n'

    return out


def _stream_output():
    for line in sys.stdin:
        sys.stdout.write(_process_line(line))


def _write_with_pager_if_needed():
    pager_command = _get_pager_command()
    if pager_command is None:
        _stream_output()
        return

    terminal_rows = _get_terminal_rows()
    buffered_output = []
    buffered_rows = 0
    pager_process = None

    for line in sys.stdin:
        out = _process_line(line)

        if pager_process is not None:
            if not _write_to_pager(pager_process, out):
                _finish_pager(pager_process)
                return
            continue

        buffered_output.append(out)
        buffered_rows += _count_screen_rows(out)

        if buffered_rows > terminal_rows:
            pager_process = _start_pager(pager_command)
            if pager_process is None:
                sys.stdout.write(''.join(buffered_output))
                _stream_output()
                return

            if not _write_to_pager(pager_process, ''.join(buffered_output)):
                _finish_pager(pager_process)
                return

            buffered_output = []

    if pager_process is None:
        sys.stdout.write(''.join(buffered_output))
    else:
        _finish_pager(pager_process)


if use_pager and sys.stdout.isatty():
    _write_with_pager_if_needed()
else:
    _stream_output()
